<view class="ai-assistant-container">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="back-btn" bindtap="handleBack">
      <view class="back-icon">←</view>
    </view>
    <view class="title">中州养老ai客服</view>
    <button class="clear-btn" bindtap="clearSession">清空</button>
  </view>
  
  <!-- 聊天内容区域 -->
  <scroll-view 
    class="chat-content" 
    scroll-y="true" 
    scroll-into-view="{{scrollToMessage}}"
    bindscrolltoupper="loadMoreMessages"
    id="chat-scroll-view"
  >
    <view class="chat-list">
      <block wx:for="{{messages}}" wx:key="id">
        <!-- AI消息 -->
        <view wx:if="{{item.type === 'ai'}}" class="message-item ai-message" id="msg-{{item.id}}">
          <view class="avatar ai-avatar">AI</view>
          <view class="message-content">
            <view class="message-bubble ai-bubble {{item.thinking ? 'thinking' : ''}}">
              <text>{{item.content}}</text>
            </view>
            <view class="message-time">{{item.timestamp}}</view>
          </view>
        </view>
        
        <!-- 用户消息 -->
        <view wx:else class="message-item user-message" id="msg-{{item.id}}">
          <view class="message-content">
            <view class="message-bubble user-bubble">
              <text>{{item.content}}</text>
            </view>
            <view class="message-time">{{item.timestamp}}</view>
          </view>
          <view class="avatar user-avatar">我</view>
        </view>
      </block>
    </view>
  </scroll-view>

  
  <!-- 底部输入区域 -->
  <view class="input-area">
    <input 
      class="message-input" 
      value="{{inputMessage}}" 
      bindinput="onInputChange" 
      placeholder="请输入您的问题..." 
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <button class="send-btn" bindtap="sendMessage" disabled="{{!inputMessage}}">发送</button>
  </view>
</view>